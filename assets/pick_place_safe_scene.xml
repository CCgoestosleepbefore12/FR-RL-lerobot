<mujoco model="PickPlaceSafeScene">
    <include file="panda.xml"/>

    <option timestep=".002" noslip_iterations="5" noslip_tolerance="0" gravity="0 0 -9.81"/>

    <statistic center="0.3 0 0.4" extent=".8"/>

    <visual>
      <headlight diffuse=".4 .4 .4" ambient=".5 .5 .5"/>
      <global azimuth="160" elevation="-20" offheight="128" offwidth="128"/>
      <quality offsamples="8"/>
    </visual>

    <asset>
      <texture type="skybox" builtin="gradient" rgb1=".3 .5 .7" rgb2="0 0 0" width="32" height="512"/>
      <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
      <material name="grid" texture="grid" texrepeat="2 2" texuniform="true" reflectance="0"/>
      <material name="zone_a" rgba=".2 .3 .5 .3"/>
      <material name="zone_b" rgba=".5 .5 .2 .3"/>
      <material name="zone_c" rgba=".5 .2 .2 .3"/>
    </asset>

    <worldbody>
      <camera name="front" pos="1.3 0.0 0.7" quat="0.5963678 0.3799282 0.3799282 0.5963678" fovy="45"/>
      <light pos="0 0 3" dir="0 0 -1" diffuse="1 1 1" specular=".3 .3 .3"/>
      <light pos="0 -.5 .4" mode="targetbodycom" target="block" diffuse=".8 .8 .8" specular=".3 .3 .3"/>
      <light pos="0 .5 .4" mode="targetbodycom" target="plate" diffuse=".8 .8 .8" specular=".3 .3 .3"/>
      <geom name="floor" size="3 3 0.01" type="plane" material="grid" friction="1 0.005 0.0001"/>

      <!-- 区域A可视化标记（机械臂工作区 y < -0.15）-->
      <geom name="zone_a_marker" type="box" pos="0.4 -0.25 0.001" size="0.15 0.1 0.001"
            material="zone_a" contype="0" conaffinity="0"/>
      <!-- 区域B可视化标记（共享交接区 -0.15 < y < 0.20）-->
      <geom name="zone_b_marker" type="box" pos="0.4 0.025 0.001" size="0.15 0.175 0.001"
            material="zone_b" contype="0" conaffinity="0"/>
      <!-- 区域C可视化标记（人员专属区 y > 0.20）-->
      <geom name="zone_c_marker" type="box" pos="0.4 0.30 0.001" size="0.15 0.1 0.001"
            material="zone_c" contype="0" conaffinity="0"/>

      <!-- 方块（区域A：机械臂抓取区）-->
      <body name="block" pos="0.4 -0.2 .02">
        <freejoint name="block"/>
        <geom name="block" type="box" size=".02 .02 .02" mass="0.1" rgba=".6 .3 .6 1"/>
      </body>

      <!-- 放置目标（区域B：共享交接区）— arrange_box风格的扁平色标 -->
      <body name="plate" pos="0.4 0.05 0">
        <geom name="plate" type="box" size=".05 .05 .005" contype="0" conaffinity="0"
              rgba=".3 .6 .3 .35"/>
      </body>

      <!-- 人手模型（球体，不参与物理碰撞，仅用于可视化和安全检测）-->
      <body name="human_hand" pos="0.4 0.5 0.05">
        <geom name="human_hand" type="sphere" size="0.035"
              rgba="1.0 0.8 0.6 0.0" contype="0" conaffinity="0"/>
      </body>
      <body name="human_hand_2" pos="0.4 0.5 0.05">
        <geom name="human_hand_2" type="sphere" size="0.035"
              rgba="0.6 0.8 1.0 0.0" contype="0" conaffinity="0"/>
      </body>
      <body name="human_hand_3" pos="0.4 0.5 0.05">
        <geom name="human_hand_3" type="sphere" size="0.035"
              rgba="0.6 1.0 0.6 0.0" contype="0" conaffinity="0"/>
      </body>

      <!-- OSC控制用的mocap目标 -->
      <body name="target" pos=".15 0 .5" quat="0 1 0 0" mocap="true">
        <geom name="target" type="box" size=".03 .03 .03" contype="0" conaffinity="0" rgba=".6 .3 .3 0"/>
      </body>
    </worldbody>

    <sensor>
      <framepos name="block_pos" objtype="geom" objname="block"/>
      <framequat name="block_quat" objtype="geom" objname="block"/>
      <framepos name="plate_pos" objtype="geom" objname="plate"/>
      <framequat name="plate_quat" objtype="geom" objname="plate"/>
    </sensor>
  </mujoco>
