__pycache__/
*.pyc
*.egg-info/
dist/
build/
.eggs/
wandb/
outputs/
# 2026-04-30 重组后 backup_policy ckpts 移到 checkpoints/backup_policy/。
# 用 `checkpoints/*` 而非 `checkpoints/`，允许 git 看到 backup_policy/ 子树
# （gitignore 规则：父目录被 ignore 时，子文件无法 re-include）。
checkpoints/*
!checkpoints/backup_policy/
*.pt
*.pth

# Per-robot calibration artifacts and downloaded model files
calibration_data/

# Debug/smoke-test outputs
d455_color.png
d455_depth.png
debug_aruco_frame.png

# BiasMonitor npz/png dumps
bias_*.npz
charts/

# Task policy demo pickles (per-robot teleop recordings, too large for git)
# 2026-04-30 数据重组：data/{no_bias|with_bias}/{task}/*.pkl，统一 ignore
data/**/*.pkl
data/**/*.pkl.bak

# Auto-generated dataset statistics
dataset_stats_generated.json

# pytest
.pytest_cache/
