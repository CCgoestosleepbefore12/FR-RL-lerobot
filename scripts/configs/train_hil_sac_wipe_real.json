{
    "env": {
        "type": "gym_manipulator",
        "fps": 10,
        "robot": null,
        "teleop": {
            "type": "spacemouse"
        },
        "processor": {
            "control_mode": "spacemouse",
            "gripper": {
                "use_gripper": true,
                "gripper_penalty": -0.05
            },
            "reset": {
                "reset_time_s": 3.0,
                "control_time_s": 30.0,
                "terminate_on_success": true
            }
        },
        "franka_config": {
            "reward_backend": "keyboard",
            "enable_bias_monitor": true,
            "display_image": true,
            "gripper_locked": "closed",
            "max_episode_length": 300,
            "encoder_bias_config": {
                "enable": true,
                "error_probability": 1.0,
                "target_joints": [
                    0
                ],
                "bias_mode": "random_uniform",
                "bias_range": [
                    -0.2,
                    0.2
                ]
            }
        },
        "name": "franka_real"
    },
    "policy": {
        "type": "sac",
        "input_features": {
            "observation.images.front": {
                "type": "VISUAL",
                "shape": [
                    3,
                    128,
                    128
                ]
            },
            "observation.images.wrist": {
                "type": "VISUAL",
                "shape": [
                    3,
                    128,
                    128
                ]
            },
            "observation.state": {
                "type": "STATE",
                "shape": [
                    29
                ]
            }
        },
        "output_features": {
            "action": {
                "type": "ACTION",
                "shape": [
                    7
                ]
            }
        },
        "device": "cuda",
        "storage_device": "cpu",
        "vision_encoder_name": "facebook/dinov3-vits16-pretrain-lvd1689m",
        "freeze_vision_encoder": true,
        "shared_encoder": true,
        "image_encoder_hidden_dim": 32,
        "image_embedding_pooling_dim": 8,
        "state_encoder_hidden_dim": 256,
        "latent_dim": 256,
        "num_discrete_actions": null,
        "online_steps": 50000,
        "online_buffer_capacity": 50000,
        "offline_buffer_capacity": 50000,
        "online_step_before_learning": 500,
        "critic_only_online_steps": 2000,
        "offline_warmup_steps": 500,
        "offline_only_mode": false,
        "offline_pretrain_steps": 5000,
        "demo_pickle_paths": [
            "data/with_bias/wipe/*.pkl"
        ],
        "demo_key_map": {
            "agent_pos": "observation.state",
            "environment_state": "observation.environment_state",
            "pixels.front": "observation.images.front",
            "pixels.wrist": "observation.images.wrist"
        },
        "demo_transpose_hwc_to_chw": [
            "observation.images.front",
            "observation.images.wrist"
        ],
        "demo_resize_images": {
            "observation.images.front": [
                128,
                128
            ],
            "observation.images.wrist": [
                128,
                128
            ]
        },
        "demo_normalize_to_unit": [
            "observation.images.front",
            "observation.images.wrist"
        ],
        "dataset_stats": null,
        "discount": 0.97,
        "temperature_init": 0.1,
        "target_entropy": -3.5,
        "num_critics": 2,
        "critic_lr": 0.0003,
        "actor_lr": 0.0003,
        "temperature_lr": 0.0003,
        "critic_target_update_weight": 0.005,
        "utd_ratio": 2,
        "grad_clip_norm": 40.0,
        "use_torch_compile": false,
        "push_to_hub": false,
        "actor_learner_config": {
            "learner_host": "127.0.0.1",
            "learner_port": 50051,
            "policy_parameters_push_frequency": 4
        },
        "concurrency": {
            "actor": "threads",
            "learner": "threads"
        }
    },
    "dataset": null,
    "output_dir": "checkpoints/wipe_real",
    "job_name": "frrl_wipe_real",
    "seed": 1000,
    "batch_size": 128,
    "steps": 100000,
    "log_freq": 100,
    "save_freq": 1000,
    "save_checkpoint": true,
    "wandb": {
        "enable": true,
        "project": "real_fr_rl",
        "entity": null
    }
}